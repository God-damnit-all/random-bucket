{
    "version": "7.5.0",
    "description": "Git utilities: repo summary, repl, changelog population, author commit percentages and more",
    "homepage": "https://github.com/tj/git-extras",
    "license": "MIT",
    "depends": "7zip19.00-helper",
    "suggest": {
        "git": "git"
    },
    "url": "https://github.com/tj/git-extras/archive/7.5.0.zip#/dl.zip_",
    "hash": "298f156dc7b73781721377860aa3d4199eae364dbe1bcab389eaacf7d069642e",
    "pre_install": [
        "[void](New-Item \"$dir\\..\\git-extras-$version\" -Target $dir -Type J)",
        "[void](Invoke-ExternalCommand 7z1900-helper -Args @('x', '-bso0', \"$dir\\dl.zip_\", \"-o$dir\\..\"))",
        "# Workaround for Invoke-ExternalCommand messing up console output in some environments due to a trailing return character",
        "[Console]::Write(\"`r\" + ' ' * [Console]::BufferWidth + \"`rRunning pre_install script...\")"
    ],
    "post_install": [
        "Remove-Item -PSPath \"$dir\\dl.zip_\"",
        "Remove-Item -PSPath \"$dir\\..\\git-extras-$version\" -Recurse",
        "& \"$dir\\install.cmd\""
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/tj/git-extras/archive/$version.zip#/dl.zip_"
    }
}
