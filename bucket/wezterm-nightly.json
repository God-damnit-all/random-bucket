{
    "version": "[\"59d94d",
    "description": "GPU-accelerated terminal emulator (nightly builds)",
    "homepage": "https://github.com/wez/wezterm",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/wez/wezterm/releases/download/nightly/WezTerm-windows-nightly.zip",
            "hash": "d31bd68440d5ec9c134342a2943cdcddb792570563e16d0fe514b5859d64e71d"
        }
    },
    "installer": {
        "script": [
            "$subDir = (Get-ChildItem -PSPath $dir -Filter WezTerm-windows-*).Name",
            "Get-ChildItem -PSPath $dir\\$subDir | Move-Item -Destination $dir",
            "Remove-Item -PSPath $dir\\$subDir",
            "[void](New-Item $persist_dir\\wezterm_modules -Type D -Force)",
            "if (New-Item $persist_dir\\wezterm.lua -ea 0) {",
            "Set-Content -PSPath $persist_dir\\wezterm.lua 'return {}'",
            "}"
        ]
    },
    "persist": [
        "wezterm_modules",
        "wezterm.lua"
    ],
    "bin": [
        "wezterm.exe",
        "wezterm-gui.exe"
    ],
    "shortcuts": [
        [
            "wezterm-gui.exe",
            "WezTerm"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/wezterm/wezterm/actions/workflows/551514/runs?status=success",
        "jsonpath": "$.workflow_runs..head_sha",
        "regex": "^[^A-Fa-F0-9]*(.{8})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wez/wezterm/releases/download/nightly/WezTerm-windows-nightly.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
