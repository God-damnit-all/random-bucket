    "checkver": {
        "url": "https://api.github.com/repos/wezterm/wezterm/actions/workflows/551514/runs?status=success",
        "jsonpath": "$.workflow_runs..head_sha",
        "regex": "^(.{8})"
    },
    "autoupdate": {
