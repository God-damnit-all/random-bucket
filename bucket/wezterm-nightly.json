{
    "version": "76b606ec",
    "description": "GPU-accelerated terminal emulator (nightly builds)",
    "homepage": "https://github.com/wez/wezterm",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/wez/wezterm/releases/download/nightly/WezTerm-windows-nightly.zip#/76b606ec.zip",
            "hash": "19b79d7d51e6c37f344c5ca665a7b0700b6c00e7e9a3ba66216a1a7ac6396ae4"
        }
    },
    "installer": {
        "script": [
            "$subDir = Get-ChildItem -PSPath $dir -Filter WezTerm-windows-*",
            "Get-ChildItem -PSPath $subDir | Move-Item -Destination $dir",
            "Remove-Item -PSPath $subDir",
            "[void](New-Item $persist_dir\\wezterm_modules -Type D -Force)",
            "if (New-Item $persist_dir\\wezterm.lua -ea 0) {",
            "  Set-Content -PSPath $persist_dir\\wezterm.lua 'return {}'",
            "}"
        ]
    },
    "persist": [
        "wezterm_modules",
        "wezterm.lua"
    ],
    "bin": [
        "wezterm.exe",
        "wezterm-gui.exe"
    ],
    "shortcuts": [
        [
            "wezterm-gui.exe",
            "WezTerm"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/wezterm/wezterm/actions/workflows/551514/runs?status=success",
        "jsonpath": "$.workflow_runs..head_sha",
        "regex": "^[^A-Fa-f0-9]*(.{8})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wez/wezterm/releases/download/nightly/WezTerm-windows-nightly.zip#/$version.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
