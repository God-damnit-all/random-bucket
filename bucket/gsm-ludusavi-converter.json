{
    "version": "2.0.0",
    "description": "A tool to convert the game save backup files created by GameSave Manager to files for another game save backup tool called Ludusavi (and vice-versa)",
    "notes": [
        "The `gsm_ludusavi_converter_cli`/`gsm-ludusavi-converter-cli` shims automatically include `--no-gui` as a parameter.",
        "The `gsm_ludusavi_converter_gui`/`gsm-ludusavi-converter-gui` shims automatically include `--gui` as a parameter.",
        "Parameters can be found here: https://github.com/jose-l-martins/GSM-Ludusavi-converter#command-line-cli"
    ],
    "homepage": "https://github.com/jose-l-martins/GSM-Ludusavi-converter",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/jose-l-martins/GSM-Ludusavi-converter/releases/download/v2.0.0/gsm_ludusavi_converter_win64.zip",
            "hash": "sha256:7d0438c2558d172a35c2bb30b6dca8d0b0b171d5f920fb5f7a6d53e487680ca7"
        }
    },
    "installer": {
        "script": [
            "[void](New-Item $persist_dir -Type D -Force)",
            "[void](New-Item ([System.IO.Path]::Combine($persist_dir, 'app.log')) -ea 0)",
            "[void](New-Item ([System.IO.Path]::Combine($persist_dir, 'config.yaml')) -ea 0)",
            "$bat = @'",
            "@ECHO OFF & PUSHD \"%~dp0\"",
            "{0} %*",
            "POPD",
            "'@",
            "Set-Content -PSPath ([System.IO.Path]::Combine($dir, 'gsm_ludusavi_converter_cli.cmd')) ($bat -f 'gsm_ludusavi_converter.exe --no-gui')",
            "Set-Content -PSPath ([System.IO.Path]::Combine($dir, 'gsm_ludusavi_converter_gui.cmd')) ($bat -f 'gsm_ludusavi_converter.exe --gui')",
            "Set-Content -PSPath ([System.IO.Path]::Combine($dir, 'gsm_ludusavi_converter.cmd')) ($bat -f 'gsm_ludusavi_converter.exe')"
        ]
    },
    "shortcuts": [
        [ "gsm_ludusavi_converter.exe", "GSM-Ludusavi Converter" ]
    ],
    "bin": [
        [ "gsm_ludusavi_converter.cmd", "gsm_ludusavi_converter" ],
        [ "gsm_ludusavi_converter.cmd", "gsm-ludusavi-converter" ],
        [ "gsm_ludusavi_converter_cli.cmd", "gsm_ludusavi_converter_cli" ],
        [ "gsm_ludusavi_converter_cli.cmd", "gsm-ludusavi-converter-cli" ],
        [ "gsm_ludusavi_converter_gui.cmd", "gsm_ludusavi_converter_gui" ],
        [ "gsm_ludusavi_converter_gui.cmd", "gsm-ludusavi-converter-gui" ]
    ],
    "persist": [
        "app.log",
        "config.yaml"
    ],
    "checkver": {
        "github": "https://github.com/jose-l-martins/GSM-Ludusavi-converter"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jose-l-martins/GSM-Ludusavi-converter/releases/download/v$version/gsm_ludusavi_converter_win64.zip"
            }
        }
    }
}
