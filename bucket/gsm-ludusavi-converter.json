{
    "version": "2.0.0",
    "description": "A tool to convert the game save backup files created by GameSave Manager to files for another game save backup tool called Ludusavi (and vice-versa)",
    "notes": "The gsm_ludusavi_converter/gsm-ludusavi-converter shims automatically include `--no-gui` as a parameter for CLI use",
    "homepage": "https://github.com/jose-l-martins/GSM-Ludusavi-converter",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/jose-l-martins/GSM-Ludusavi-converter/releases/download/v2.0.0/gsm_ludusavi_converter_win64.zip",
            "hash": "sha256:7d0438c2558d172a35c2bb30b6dca8d0b0b171d5f920fb5f7a6d53e487680ca7"
        }
    },
    "installer": {
        "script": "Set-Content -PSPath $dir\\gsm_ludusavi_converter.bat '@%~dpn0.exe --no-gui %*'"
    },
    "shortcuts": [
        [ "gsm_ludusavi_converter.exe", "GSM-Ludusavi-converter" ]
    ],
    "bin": [
        [ "gsm_ludusavi_converter.bat", "gsm_ludusavi_converter" ],
        [ "gsm_ludusavi_converter.bat", "gsm-ludusavi-converter" ]
    ],
    "checkver": {
        "github": "https://github.com/jose-l-martins/GSM-Ludusavi-converter"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jose-l-martins/GSM-Ludusavi-converter/releases/download/v$version/gsm_ludusavi_converter_win64.zip"
            }
        }
    }
}
